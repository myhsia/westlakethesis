% Start the optionlist |wu-class| for \pkg{l3docstrip}.
%    \begin{macrocode}
%<*wu-class>
%    \end{macrocode}
% \begin{macro}
%   {
%     \@@_msg_new:nn,
%     \@@_msg_error:nn,
%     \@@_msg_warning:nn,
%     \@@_msg_info:nn,
%   }
% Message management: private functions for creating new message and
% broadcasting it as error, warning, or info.
%    \begin{macrocode}
\cs_new_protected:Npn \@@_msg_new:nn #1#2
  { \msg_new:nnn     { WESTLAKEthesis } {#1} {#2} }
\cs_new_protected:Npn \@@_msg_error:nn #1#2
  { \msg_error:nnn   { WESTLAKEthesis } {#1} {#2} }
\cs_new_protected:Npn \@@_msg_warning:nn #1#2
  { \msg_warning:nnn { WESTLAKEthesis } {#1} {#2} }
\cs_new_protected:Npn \@@_msg_info:nn #1#2
  { \msg_info:nnn    { WESTLAKEthesis } {#1} {#2} }
%    \end{macrocode}
% \end{macro}
% New message: |not found module|, will be used in \cs{@@_load_module:n}.
%    \begin{macrocode}
\@@_msg_new:nn { not found module }
  { The ~ WESTLAKEthesis ~ module ~ `#1' ~ not ~ found. }
%    \end{macrocode}
% New message: |unknown mode| for global option |mode| key.
%    \begin{macrocode}
\@@_msg_new:nn { unknown mode }
  { Couldn't ~ load ~ the ~ `#1' ~ mode ~ of ~ WESTLAKEthesis. }
%    \end{macrocode}
% \begin{macro}{\@@_unknown_option:n}
% Function for passing unknown options to the basic class.
%    \begin{macrocode}
\cs_new_protected_nopar:Npn \@@_unknown_option:n #1
  {
    \tl_if_empty:nTF {#1}
      {
        \clist_gput_right:NV \g_@@_base_class_opt_clist \l_keys_key_str
      }
      {
        \exp_args:NNx \clist_gput_right:Nn \g_@@_base_class_opt_clist
          { \l_keys_key_str = \exp_not:n {#1} }
      }
}
%    \end{macrocode}
% \begin{variable}{\g_@@_base_class_opt_clist}
% Variable for storing basic class options.
%    \begin{macrocode}
\clist_clear_new:N \g_@@_base_class_opt_clist
%    \end{macrocode}
% \end{variable}
% \end{macro}
% \begin{macro}{\@@_load_module:N}
% Functions for loading module in \file{westlakethesis.cls}.
%    \begin{macrocode}
\cs_new_protected_nopar:Npn \@@_load_module:N #1
  {
    \clist_map_inline:Nn #1
      {
        \file_if_exist_input:nF { wu-##1.code.tex }
          { \@@_msg_error:nn { not found module } { ##1 } }
      }
  }
%    \end{macrocode}
% \end{macro}
% Load the modules respectively under different modes.
% \begin{itemize}
%   \item |driver|: Loading the base class and required packages.
%   \item |kernel|: Inner functions for the |layout| module.
%   \item |params|: Storing the constant variables.
%   \item |layout|: Formats of Westlake University dissertations.
% \end{itemize}
%    \begin{macrocode}
\clist_new:N \g_@@_required_modules_clist
\keys_define:nn { @@ / classoption }
  {
    mode          .choices:nn = { thesis, l3xdoc, beamer, poster } {},
    mode          .default:n  = { thesis },
    mode / thesis .code:n     =
      {
        \clist_gset:Nn \g_@@_required_modules_clist
          { driver, kernel, params, layout }
      },
    mode / l3xdoc .code:n     =
      { \clist_gset:Nn \g_@@_required_modules_clist { l3xdoc } },
    mode / beamer .code:n     =
      {
        \clist_gset:Nn \g_@@_required_modules_clist
          { beamer, kernel, params }
      },
    mode / poster .code:n     =
      { \clist_gset:Nn \g_@@_required_modules_clist { poster } },
    mode / unknown.code:n     =
      { \@@_msg_error:nn { unknown mode } {#1}                 },
    unknown .code:n           = \@@_unknown_option:n {#1},
  }
\keys_set:nn { @@ / classoption } { mode = thesis }
\ProcessKeyOptions [ @@ / classoption ]
\@@_load_module:N \g_@@_required_modules_clist
%    \end{macrocode}
% \begin{macro}{\westlakeset}
% \hologo{LaTeX2e} user's interface for filling information,
% only valid in preamble.
%    \begin{macrocode}
\@onlypreamble \westlakeset
\NewDocumentCommand \westlakeset { m }
  {
    \keys_set:nn { @@ / set } {#1}
%    \end{macrocode}
% Parsing the bilingualism of the items |title|, |school|, |subject|, |author|,
% and |PI| after filling information, then decide
% \hyperlink{bool:gbt7714_load}{whether to load the \pkg{gbt7714} package} by
% \hypertarget{bool:gbt7714_set}{setting the boolean \cs{l_@@_load_bib_bool}}.
%    \begin{macrocode}
    \clist_map_inline:nn { title, school, subject, author, PI }
      { \@@_parse_slash_ab:c { l_@@_set_##1_tl } }
    \str_if_empty:NF \l_@@_set_bib_str
      { \bool_gset_true:N \l_@@_load_bib_bool }
  }
%    \end{macrocode}
% \begin{variable}
%   {
%     \l_@@_set_id_tl,
%     \l_@@_set_title_tl,
%     \l_@@_set_school_tl,
%     \l_@@_set_subject_tl,
%     \l_@@_set_author_tl,
%     \l_@@_set_PI_tl,
%     \l_@@_set_master_bool,
%     \l_@@_set_bib_str,
%   }
% Key–value definitions for the \tn{westlakeset} command.
%    \begin{macrocode}
\keys_define:nn { @@ / set }
  {
    id        .tl_set:N   = \l_@@_set_id_tl,
      id      .initial:n  = { \int_value:w \c_sys_year_int 0000000 },
    title     .tl_set:N   = \l_@@_set_title_tl,
    school    .tl_set:N   = \l_@@_set_school_tl,
    subject   .tl_set:N   = \l_@@_set_subject_tl,
    author    .tl_set:N   = \l_@@_set_author_tl,
    PI        .tl_set:N   = \l_@@_set_PI_tl,
    master    .bool_set:N = \l_@@_set_master_bool,
      master  .initial:n  = false,
      master  .default:n  = true,
    bibsource .str_set:N  = \l_@@_set_bib_str,
  }
%    \end{macrocode}
% \end{variable}
% \end{macro}
% End the optionlist |wu-class| for \pkg{l3docstrip}.
%    \begin{macrocode}
%</wu-class>
%    \end{macrocode}
% \subsection{\texttt{wu-driver.code.tex}}
% Start the optionlist |wu-driver| for \pkg{l3docstrip}.
%    \begin{macrocode}
%<*wu-driver>
%    \end{macrocode}
% Prevent the warnings raised by \pkg{xeCJK} (valid for \hologo{XeTeX})
% when redefining fonts.
%    \begin{macrocode}
\sys_if_engine_xetex:T
  { \PassOptionsToPackage { quiet } { xeCJK } }
%    \end{macrocode}
% Load the base class: \cls{ctexrep}, with the options
% \begin{multicols}{2}
% \begin{itemize}
%   \item Paper size: |a4paper|,
%   \item Font size: |-4| (small 4 hao),
%   \item Line spread: |1.5|, and
%   \item Font set: \href{https://ctan.org/pkg/lxgw-fonts}{|lxgw|}.
% \end{itemize}
% \end{multicols}
%    \begin{macrocode}
\clist_gset:Nn \g_@@_base_class_opt_clist
  { a4paper, zihao = -4, linespread = 1.5, fontset = lxgw }
%    \end{macrocode}
%    \begin{macrocode}
\exp_args:NNV \LoadClass [ \g_@@_base_class_opt_clist ] { ctexrep }
%    \end{macrocode}
% Load the required packages, where the |titles| option is passed to the
% \pkg{tocloft} package to make ToC, LoF, and LoT lists to be typeset using the
% default \hologo{LaTeX} methods.
%    \begin{macrocode}
\RequirePackage { graphicx, hyperref,  geometry, array,
                  lmodern,  newtxtext, lipsum,   zhlipsum }
\RequirePackage [ titles ] { tocloft }
%    \end{macrocode}
% Configure the possible paths for searching figures.
%    \begin{macrocode}
\graphicspath
  {
    {./fig/}  {./pic/}  {./figure/}  {./picture/}  {./media/}
    {./figs/} {./pics/} {./figures/} {./pictures/}
  }
%    \end{macrocode}
% Configure the metadata of the document via \pkg{hyperref}.
%    \begin{macrocode}
\hypersetup { hidelinks }
%    \end{macrocode}
% Loading the \pkg{microtype} package to obtain a better typeset effect
% (only valid for \hologo{pdfTeX}, \hologo{XeTeX}, and~\hologo{LuaTeX}).
%    \begin{macrocode}
\bool_lazy_or:nnT { \sys_if_engine_pdftex_p: } { \sys_if_engine_opentype_p: }
  { \RequirePackage { microtype } }
%    \end{macrocode}
% \hypertarget{bool:gbt7714_load}{Determine whether to load the \pkg{gbt7714}
%   package due to the boolean \cs{l_@@_load_bib_bool}}, which has been set via
% \tn{westlakeset} \hyperlink{bool:gbt7714_set}{here}.
%    \begin{macrocode}
\hook_gput_code:nnn { env / document / before } { . }
  {
    \bool_if:NT \l_@@_load_bib_bool
      {
        \RequirePackage [ sort, uppercasefamily = false ] { gbt7714 }
        \bibliographystyle { gbt7714-numeric }
      }
  }
%    \end{macrocode}
% End the optionlist |wu-driver| for \pkg{l3docstrip}.
